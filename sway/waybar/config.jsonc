{
  "style": "~/.config/waybar/style.css",
  
  "layer": "top",
  "position": "top",
  "height": 10,
  
  "modules-center": [
    "sway/window"
  ],
  
  "modules-left": [
    "sway/workspaces"
  ],
  
  "modules-right": [
    "pulseaudio",
    "temperature",
    "cpu",
    "network",
    "memory",
    "clock",
    "tray"
  ],

  "include": "~/.config/waybar/modules.jsonc"
}
